<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Club Sportivo Trinidense</title>

    <link rel="stylesheet" href="style.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>

<body>

    <!-- HEADER -->
    <header>

        <div class="logo-section">
            <img src="logo.png" alt="Logo Trinidense">
            <h1>Club Sportivo Trinidense</h1>
        </div>

        <nav>
            <a href="#">Inicio</a>
            <a href="#">Historia</a>
            <a href="#">Plantel</a>
            <a href="#">Hinchas</a>
            <a href="#">Tienda</a>
            <a href="#">Contacto</a>
        </nav>

    </header>

    <!-- HERO -->

    <section class="hero">

        <div class="overlay">

            <h2>Pasión Auriazul</h2>

            <p>
                La pasión del Barrio Santísima Trinidad
                conectada con sus hinchas.
            </p>

            <button>Explorar Club</button>

        </div>

    </section>

    <!-- PARTIDOS -->

    <section class="matches">

        <h2>Próximo Partido</h2>

        <div class="match-card">

            <div class="team">
                <img src="logo.png">
                <h3>Trinidense</h3>
            </div>

            <div class="vs">
                VS
            </div>

            <div class="team">
                <img src="logo.png">
                <h3>Rival</h3>
            </div>

        </div>

    </section>

    <!-- HISTORIA -->

    <section class="history">

        <h2>Historia del Club</h2>

        <p>
            El Club Sportivo Trinidense representa
            la pasión, tradición y compromiso del
            Barrio Santísima Trinidad, fortaleciendo
            el vínculo con sus hinchas a través del
            deporte y la identidad auriazul.
        </p>

    </section>

    <!-- FOOTER -->

    <footer>

        <p>© 2026 Club Sportivo Trinidense</p>

    </footer>

<script src="script.js"></script>

</body>
</html>
